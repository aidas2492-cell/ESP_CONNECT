# Laissez vide en développement : le proxy Vite (vite.config.js) redirige
# automatiquement /api et /socket.io vers http://localhost:5000.
#
# En production, renseignez l'URL complète de votre backend déployé, par ex :
# VITE_API_URL=https://esp-connect-api.onrender.com/api
# VITE_SOCKET_URL=https://esp-connect-api.onrender.com
VITE_API_URL=
VITE_SOCKET_URL=
