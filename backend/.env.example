# Serveur
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=esp_digital
DB_USER=root
DB_PASSWORD=

# JWT
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=7d

# Email (Nodemailer - ex: Gmail SMTP ou Mailtrap en dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Plateforme ESP <no-reply@esp.sn>"
